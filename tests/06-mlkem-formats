# Drive each format through import / -Gp round-trip / encrypt / decrypt.
# (Loop label avoids "exp" because $EXP is reserved by vestest().)
for FORMAT in seed expkey both; do
    case $FORMAT in
        seed)   IN=$SEED ;;
        expkey) IN=$EXPK ;;
        both)   IN=$BOTH ;;
    esac
    KSEC="${EMAIL}%21mlk-${FORMAT}-${NONCE}"
    OBJK="//demo/mlk-${FORMAT}-${NONCE}"

    vestest_head "[$FORMAT] import an ML-KEM-768 PEM (CHOICE = $FORMAT)"
    vestest 0 -a //$DOM/$EMAIL/ -k $KSEC/$EMAIL -yf $IN -n -E save

    vestest_head "[$FORMAT] -Gp round-trip reports OQS:ML-KEM-768"
    vestest - <<TEST -a //$DOM/$EMAIL/ -k $KSEC/ -Gp -E
OQS:ML-KEM-768
TEST

    # The three CHOICE forms encode the same key material, so libVES's
    # SPKI -Yp output must be byte-identical for all of them. The expected
    # PEM below is the deterministic SPKI for the inlined private key.
