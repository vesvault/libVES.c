#!/bin/bash

# Exercises ML-KEM private key import across the three FIPS 203
# (draft-ietf-lamps-kyber-certificates) PrivateKey CHOICE alternatives:
#
#   ML-KEM-PrivateKey ::= CHOICE {
#       seed        [0] IMPLICIT OCTET STRING,
#       expandedKey     OCTET STRING,
#       both            SEQUENCE { seed OCTET STRING, expandedKey OCTET STRING }
#   }
#
# Each format hits a different branch of libVES_KeyAlgo_MLKEM_materialize:
#   - seed: OQS_KEM_keypair_derand (requires libOQS >= 0.13)
#   - expandedKey: direct copy + derive pub from expanded
#   - both: direct copy of expanded, seed ignored
#
# The three test keys below were pre-generated offline from a single
# `openssl genpkey -algorithm ML-KEM-768` run (PKCS8 v0 / CHOICE = both)
# and re-encoded into the other two CHOICE forms via raw DER edits.
# They share the same underlying key material - importing any of them
# should yield identical public keys. Inlined as static PEMs so the
# test depends only on bash + the ves CLI at runtime (no openssl /
# python required).

DIR=$(dirname $(realpath $0))

. $DIR/vestest.inc.sh

vestest_init $EMAIL

SEED=$(mktemp /tmp/vestest-mlk-seed-${NONCE}-XXXX.pem)
EXPK=$(mktemp /tmp/vestest-mlk-exp-${NONCE}-XXXX.pem)
BOTH=$(mktemp /tmp/vestest-mlk-both-${NONCE}-XXXX.pem)

